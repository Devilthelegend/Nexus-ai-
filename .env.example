# NexusAI environment configuration
#
# Copy this file to `.env` (`cp .env.example .env`) to run NexusAI locally.
# The defaults below boot the FULL application with ZERO external services and
# NO API keys: a local SQLite database, deterministic mock LLM/embedding
# providers, and an in-memory vector store. This is the fastest path to manual
# testing. Swap in the Postgres/Qdrant/Redis values (see comments) for a
# production-like stack.

# --- Application ---
APP_NAME=NexusAI
ENVIRONMENT=local
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Data stores ---
# Zero-infra default: a local SQLite file (no database server required).
# Tables are created automatically on startup when DB_AUTO_CREATE=true (below).
DATABASE_URL=sqlite+aiosqlite:///./nexus.db
# Production-like alternative (requires `docker compose up -d postgres`):
# DATABASE_URL=postgresql+asyncpg://nexus:nexus@localhost:5432/nexus

# Redis and Qdrant are only used when you opt into the production stack; the
# offline defaults (memory vector store, inline ingestion) do not touch them.
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333

# Auto-create tables on startup (convenient for local/SQLite runs). Leave this
# false in production and use Alembic migrations (`alembic upgrade head`).
DB_AUTO_CREATE=true

# --- Authentication / JWT ---
# Use a strong, random secret of at least 32 bytes in any real deployment.
JWT_SECRET_KEY=local-dev-secret-change-me-please-32bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- LLM provider (mock runs fully offline, no credentials) ---
# Set LLM_PROVIDER=openai (with LLM_API_KEY) to use OpenAI or any
# OpenAI-compatible endpoint (Groq, OpenRouter, local server) via LLM_BASE_URL.
# Keep credentials in env/secrets only; never commit a real key.
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL=mock-chat-001
LLM_BASE_URL=https://api.openai.com/v1
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=0
LLM_COST_PER_1K_TOKENS=0.0

# --- Embeddings (mock is deterministic and offline) ---
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=mock-embed-001
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=64

# --- Vector store: "memory" (offline default) or "qdrant" ---
VECTOR_BACKEND=memory
QDRANT_COLLECTION=nexus_chunks

# --- Ingestion: run the pipeline inline (no Celery worker needed) ---
INGEST_EAGER=true

# --- Retrieval / RAG ---
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
CONTEXT_TOKEN_BUDGET=2000

# --- Agent orchestration ---
AGENT_MAX_STEPS=4
AGENT_MEMORY_ENABLED=true
AGENT_SHORT_TERM_TURNS=6
AGENT_LONG_TERM_TOP_K=3
AGENT_LONG_TERM_MAX_ENTRIES=256

# --- Rate limiting (fixed-window, per user/IP) ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# --- Semantic cache (workspace-scoped RAG answer reuse) ---
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.95
SEMANTIC_CACHE_MAX_ENTRIES=512

# --- Document storage and upload limits ---
UPLOAD_DIR=./var/uploads
MAX_UPLOAD_BYTES=52428800

# --- Chunking ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# --- Observability & security hardening ---
METRICS_ENABLED=true
SECURITY_HEADERS_ENABLED=true
OTEL_ENABLED=false
SENTRY_DSN=
